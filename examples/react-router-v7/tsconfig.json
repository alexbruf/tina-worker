{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client", "node"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noEmit": true,
    "rootDirs": [".", ".react-router/types"],
    "paths": { "~/*": ["./app/*"] }
  },
  "include": [
    ".react-router/types/**/*",
    "app/**/*",
    "tina/**/*",
    "workers/**/*",
    "worker-configuration.d.ts"
  ]
}
