    "@cloudflare/vite-plugin": "^1.0.0",
    "@react-router/node": "^7.0.0",
    "@tinacms/datalayer": "^2.0.13",
    "isbot": "^5.1.0",
    "process": "^0.11.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "tinacms": "^2.6.0",
    "tinacms-clerk": "^21.0.0",
    "tinacms-gitprovider-github": "^4.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
