{
  "name": "tina-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "tinacms build --skip-indexing && wrangler deploy",
    "tina:build": "tinacms build --skip-indexing",
    "tina:dev": "tinacms dev -c \"wrangler dev\"",
    "install-hooks": "bash scripts/install-hooks.sh"
  },
  "dependencies": {
    "@alexbruf/d1-level": "0.2.0",
    "@clerk/backend": "^3.2.3",
    "@tinacms/datalayer": "^2.0.13",
    "express": "^5.2.1",
    "tinacms": "^2.6.0",
    "tinacms-clerk": "^21.0.0",
    "tinacms-gitprovider-github": "^4.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@tinacms/cli": "^2.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  },
  "patchedDependencies": {
    "@tinacms/mdx@1.8.3": "patches/@tinacms%2Fmdx@1.8.3.patch",
    "@tinacms/mdx@2.1.0": "patches/@tinacms%2Fmdx@2.1.0.patch",
    "@tinacms/graphql@2.2.1": "patches/@tinacms%2Fgraphql@2.2.1.patch"
